{
    "name": "ibantest/ibantest-for-woocommerce",
    "description": "SEPA direct debit payment gateway with IBAN validation for WooCommerce.",
    "type": "wordpress-plugin",
    "license": "GPL-3.0-or-later",
    "require": {
        "php": ">=8.1",
        "ibantest/ibantest-php": "^1.0",
        "defuse/php-encryption": "^2.2",
        "digitick/sepa-xml": "^1.2"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5 || ^11.0 || ^12.0"
    },
    "autoload": {
        "psr-4": {
            "Ibantest\\WooCommerce\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Ibantest\\WooCommerce\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit -c phpunit.xml.dist",
        "i18n:pot": "wp i18n make-pot . languages/ibantest-for-woocommerce.pot --domain=ibantest-for-woocommerce --exclude=vendor,tests,node_modules,.git,build",
        "i18n:update-po": [
            "wp i18n update-po languages/ibantest-for-woocommerce.pot languages/ibantest-for-woocommerce-de_DE.po",
            "wp i18n update-po languages/ibantest-for-woocommerce.pot languages/ibantest-for-woocommerce-it_IT.po",
            "wp i18n update-po languages/ibantest-for-woocommerce.pot languages/ibantest-for-woocommerce-fr_FR.po",
            "wp i18n update-po languages/ibantest-for-woocommerce.pot languages/ibantest-for-woocommerce-nl_NL.po",
            "wp i18n update-po languages/ibantest-for-woocommerce.pot languages/ibantest-for-woocommerce-es_ES.po",
            "wp i18n update-po languages/ibantest-for-woocommerce.pot languages/ibantest-for-woocommerce-pl_PL.po"
        ],
        "i18n:mo": "wp i18n make-mo languages languages",
        "i18n:json": "wp i18n make-json languages --no-purge",
        "i18n": [
            "@i18n:pot",
            "@i18n:update-po",
            "@i18n:mo",
            "@i18n:json"
        ],
        "build:release": "php bin/build-release.php"
    },
    "authors": [
        {
            "name": "IBANTEST",
            "email": "info@ibantest.com"
        }
    ],
    "config": {
        "allow-plugins": {}
    }
}
